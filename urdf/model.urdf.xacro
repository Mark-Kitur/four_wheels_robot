<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org" name="four_wheels_robot">
    
    <xacro:property name="wheel_radius" value="0.28"/>
    <xacro:property name="wheel_length" value="0.1"/>

    <!-- Include control definitions -->
    <xacro:include filename="$(find four_wheels_robot)/urdf/ros2_wheel_controllers.xacro"/>
    <xacro:include filename="$(find four_wheels_robot)/urdf/sensors.xacro"/>

    <xacro:macro name="wheel" params="prefix">
        <link name="${prefix}_wheel">
            <inertial>
                
                <mass value="0.2"/>
                <inertia ixx="0.004087" ixy="0.0" ixz="0.0" iyy="0.004087" iyz="0.0" izz="0.007840"/>
            </inertial>
            <visual>
                <origin xyz="0.0 0.0 0.0" rpy="1.57 0.0 0.0"/>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
                </geometry>
                <material name="">
                    <color rgba="1.0 0.5 0.34 1.0"/>
                </material>
            </visual>
            <collision>
             <origin xyz="0.0 0.0 0.0" rpy="1.57 0.0 0.0"/>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
                </geometry>
            </collision>
        </link>
    </xacro:macro>

    <xacro:wheel prefix="front_left" />
    <xacro:wheel prefix="front_right"/>
    <xacro:wheel prefix="back_left"/>
    <xacro:wheel prefix="back_right" />

    <!-- Chassis -->
    <link name="base_link">
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="10.0"/> <!-- Increased mass a bit -->
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="1.3 0.8 0.4"/>
            </geometry>
            <material name="">
                <color rgba="1.0 0.0 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="1.3 0.8 0.4"/>
            </geometry>
        </collision>
    </link>
    <link name="base_footprint"/>

    <joint name="base_joint" type="fixed">
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <axis xyz="0.0 0.0 0.0"/>
    </joint>

    <!-- Wheels joints (adjusted z for ground contact) -->
    <xacro:macro name="wheel_joint" params="prefix x y r">
        <joint name="${prefix}_wheel_joint" type="continuous">
            <origin xyz="${x} ${y} -${wheel_radius}" rpy="${r} 0 0"/>
            <parent link="base_link"/>
            <child link="${prefix}_wheel"/>
            <axis xyz="0 1 0"/>
            <dynamics damping="0.1" friction="0.0"/>
        </joint>
    </xacro:macro>

    <xacro:wheel_joint prefix="front_left"  x="0.41" y="0.46" r="0"/>
    <xacro:wheel_joint prefix="front_right" x="0.41" y="-0.46" r="0"/>
    <xacro:wheel_joint prefix="back_left"   x="-0.41" y="0.46" r="0"/>
    <xacro:wheel_joint prefix="back_right"  x="-0.41" y="-0.46" r="0"/>

    <!--Adding a lidar-->
    <link name="lidar_link">
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.08"/>
            </geometry>
                <material name="">
                    <color rgba="0.78 0.55 0.34 1.0"/>
                </material>           
        </visual>
    </link>

    <joint name="liadar_joint" type="fixed">
        <origin xyz="0.0 0.0 0.2" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="lidar_link"/>
        <axis xyz="0.0 0.0 0.0"/>
        <limit lower="0.0" upper="0.0" effort="0.0" velocity="0.0"/>
    </joint>

    <!-- Adding IMU SENSOR-->
<!-- Adding IMU SENSOR -->
<link name="imu_link">
  <visual>
    <geometry>
      <box size="0.1 0.1 0.1"/>
    </geometry>
  </visual>
  <collision>
    <geometry>
      <box size="0.1 0.1 0.1"/>
    </geometry>
  </collision>
</link>

<joint name="imu_joint" type="fixed">
  <parent link="base_link"/>
  <child link="imu_link"/>
  <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
</joint>


</robot>